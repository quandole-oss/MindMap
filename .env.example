# ─── Database ───────────────────────────────────────────────────────────────
# Docker Compose (default):
DATABASE_URL=postgresql://mindmap:mindmap@localhost:5432/mindmap
# Vercel + Neon: set via Neon integration (auto-populated)

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate-a-random-secret-at-least-32-chars

# ─── LLM Providers ─────────────────────────────────────────────────────────
# Primary provider (required for AI features):
ANTHROPIC_API_KEY=sk-ant-...
# Embeddings (required for concept deduplication):
OPENAI_API_KEY=sk-...
# Provider selection (default: anthropic):
# LLM_PROVIDER=anthropic

# ─── Privacy (INFR-05) ─────────────────────────────────────────────────────
# Next.js telemetry is disabled via NEXT_TELEMETRY_DISABLED=1 in Docker
# No analytics or tracking scripts are included in the application
# All student data stays on the deployer's server

# ─── Deployment Notes ───────────────────────────────────────────────────────
# Docker Compose: Copy this file to .env, fill in API keys, run `docker compose up`
# Vercel: Set these variables in Vercel project settings (DATABASE_URL auto-set by Neon integration)
